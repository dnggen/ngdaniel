---
import Base from "../layouts/Base.astro";
import site from "../data/site.json";
import timeline from "../data/timeline.json";
import interests from "../data/interests.json";
import cars from "../data/cars.json";
import watches from "../data/watches.json";
import tailors from "../data/tailors.json";
import restaurants from "../data/restaurants.json";
import travel from "../data/travel.json";
import crypto from "../data/crypto.json";

const tailorCountries = [...new Set(tailors.map((t) => t.country))].sort();
const fineDining = restaurants.filter((r) => r.section === "fine");
const cheapEats = restaurants.filter((r) => r.section === "cheap");
---

<Base>
  <div class="wrap">
    <header class="mast">
      <h1 class="name">{site.name}</h1>
    </header>

    <section id="about">
      <h2 class="sec-title">About</h2>
      {site.about.map((p) => <p>{p}</p>)}
    </section>

    <section id="timeline">
      <h2 class="sec-title">Timeline</h2>
      <div class="story">
        {
          timeline.map((s) => (
            <div class="step">
              <span class="yr">{s.era}</span>
              <p>{s.text}</p>
              {s.items && (
                <>
                  {s.itemsLabel && <span class="step-sub">{s.itemsLabel}</span>}
                  <ul class="step-list">
                    {s.items.map((i) => (
                      <li>{i}</li>
                    ))}
                  </ul>
                </>
              )}
            </div>
          ))
        }
      </div>
    </section>

    <section id="interests">
      <h2 class="sec-title">Interests</h2>
      <div class="acc">
        {
          interests.map((it) =>
            it.static ? (
              <div class="acc-item">
                <div class="acc-row">
                  <span class="acc-name">{it.name}</span>
                  <span class="acc-dek">{it.dek}</span>
                </div>
              </div>
            ) : (
            <div class="acc-item">
              <button class="acc-head">
                <span class="acc-name">{it.name}</span>
                <span class="acc-dek">{it.dek}</span>
                <span class="acc-sign">+</span>
              </button>
              <div class="acc-panel">
                <div class="acc-inner">
                  {(it.blurb || it.link) && (
                  <p>
                    {it.blurb}
                    {it.link && (
                      <>
                        {" "}
                        <a class="inline" href={it.link.href} target="_blank" rel="noopener">
                          {it.link.text}
                        </a>
                        .
                      </>
                    )}
                  </p>
                  )}

                  {it.id === "cars" && (
                    <div class="garage">
                      {cars.map((c) => (
                        <div class="car">
                          <div class="car-img" style={c.image ? `background-image:url(${c.image})` : ""}>
                            {!c.image && <span>photo coming</span>}
                          </div>
                          <h4>{c.name}</h4>
                          <p class="specs">{c.specs}</p>
                          <span class="yrs">{c.years}</span>
                        </div>
                      ))}
                    </div>
                  )}

                  {it.id === "watches" && (
                    <div class="watches">
                      {watches.map((w) => (
                        <div class="watch">
                          <div class="watch-head">
                            <b>{w.name}</b>
                            <span class="gain">{w.gain}</span>
                          </div>
                          <p class="watch-specs">{w.specs}</p>
                          <span class="watch-meta">Acquired {w.acquired}</span>
                        </div>
                      ))}
                    </div>
                  )}

                  {it.id === "menswear" &&
                    tailorCountries.map((country) => (
                      <>
                        <div class="sub-head">{country}</div>
                        <ul class="detail-list">
                          {tailors
                            .filter((t) => t.country === country)
                            .sort((a, b) => a.name.localeCompare(b.name))
                            .map((t) => (
                              <li>
                                <span>
                                  <b>{t.name}</b>
                                </span>
                                <span class="meta">{t.specialty}</span>
                              </li>
                            ))}
                        </ul>
                      </>
                    ))}

                  {it.id === "crypto" && (
                    <>
                      <ul class="detail-list">
                        {crypto.map((c) => (
                          <li>
                            <span>{c.text}</span>
                            <span class="meta">{c.year}</span>
                          </li>
                        ))}
                      </ul>
                      <p style="margin-top:14px">
                        X:{" "}
                        <a class="inline" href="https://x.com/dnggen" target="_blank" rel="noopener">
                          @dnggen
                        </a>
                      </p>
                    </>
                  )}

                  {it.id === "food" && (
                    <>
                      <div class="sub-head">Michelin</div>
                      <ul class="detail-list">
                        {fineDining.map((r) => (
                          <li>
                            <span>
                              <b>{r.name}</b>
                              {r.cuisine ? ` — ${r.cuisine}` : ""}
                            </span>
                            <span class="meta">{r.city}</span>
                          </li>
                        ))}
                      </ul>
                      <div class="sub-head">Cheap eats</div>
                      <ul class="detail-list">
                        {cheapEats.map((r) => (
                          <li>
                            <span>
                              <b>{r.name}</b>
                              {r.cuisine ? ` — ${r.cuisine}` : ""}
                            </span>
                            <span class="meta">{r.city}</span>
                          </li>
                        ))}
                      </ul>
                      <div class="sub-head">Food crawls</div>
                      <p style="font-size:.92rem">
                        <a class="inline" href="https://maps.app.goo.gl/a6d7DTfLyrCjJ96dA" target="_blank" rel="noopener">
                          The crawl map
                        </a>{" "}
                        — routes and dates coming soon.
                      </p>
                    </>
                  )}

                  {it.id === "travel" && (
                    <ul class="travel">
                      {travel.map((t) => (
                        <li>
                          <b>{t.country}</b>
                          {t.places ? ` — ${t.places}` : ""}
                        </li>
                      ))}
                    </ul>
                  )}

                  {it.id === "photography" && (
                    <p style="margin-top:4px">
                      <a class="inline" href="/photography">View the full gallery →</a>
                    </p>
                  )}
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <section id="building">
      <h2 class="sec-title">Building</h2>
      <p class="xxx">{site.building}</p>
    </section>

    <section id="contact" class="contact">
      <h2 class="sec-title">Contact</h2>
      <div class="socials">
        {
          site.socials.map((s) => (
            <a href={s.href} target="_blank" rel="noopener">
              {s.label}
            </a>
          ))
        }
      </div>
    </section>
  </div>
</Base>
