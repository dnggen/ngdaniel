---
import Base from "../layouts/Base.astro";
import site from "../data/site.json";
import interests from "../data/interests.json";
import cars from "../data/cars.json";
import watches from "../data/watches.json";
import tailors from "../data/tailors.json";
import restaurants from "../data/restaurants.json";
import travel from "../data/travel.json";
import crypto from "../data/crypto.json";
import crawls from "../data/crawls.json";
import menswear from "../data/menswear.json";

const tailorCountries = [...new Set(tailors.map((t) => t.country))].sort();
const mwMap = Object.fromEntries(menswear.map((m) => [m.slug, m.files]));
const byRating = (a, b) => b.rating - a.rating;
const fineDining = restaurants.filter((r) => r.section === "fine").sort(byRating);
const cheapEats = restaurants.filter((r) => r.section === "cheap").sort(byRating);
---

<Base>
  <div class="wrap">
    <header class="mast">
      <h1 class="name">{site.name}</h1>
    </header>

    <section id="about">
      <h2 class="sec-title">About</h2>
      {site.about.map((p) => <p>{p}</p>)}
    </section>

    <section id="timeline">
      <h2 class="sec-title">Timeline</h2>
      <p>{site.timelineText}</p>
    </section>

    <section id="interests">
      <h2 class="sec-title">Interests</h2>
      <div class="acc">
        {
          interests.map((it) =>
            it.static ? (
              <div class="acc-item">
                <div class="acc-row">
                  <span class="acc-name">{it.name}</span>
                  <span class="acc-dek">{it.dek}</span>
                </div>
              </div>
            ) : (
            <div class="acc-item">
              <button class="acc-head">
                <span class="acc-name">{it.name}</span>
                <span class="acc-dek">{it.dek}</span>
                <span class="acc-sign">+</span>
              </button>
              <div class="acc-panel">
                <div class="acc-inner">
                  {(it.blurb || it.link) && (
                  <p>
                    {it.blurb}
                    {it.link && (
                      <>
                        {" "}
                        <a class="inline" href={it.link.href} target="_blank" rel="noopener">
                          {it.link.text}
                        </a>
                        .
                      </>
                    )}
                  </p>
                  )}

                  {it.id === "cars" && (
                    <div class="garage">
                      {cars.map((c) => (
                        <div class="car">
                          <div class="car-img" style={c.image ? `background-image:url(${c.image})` : ""}>
                            {!c.image && <span>photo coming</span>}
                          </div>
                          <h4>{c.name}</h4>
                          <p class="specs">{c.specs}</p>
                          <span class="yrs">{c.years}</span>
                        </div>
                      ))}
                    </div>
                  )}

                  {it.id === "watches" && (
                    <div class="watches">
                      {watches.map((w) => (
                        <div class="watch">
                          <div class="watch-head">
                            <b>{w.name}</b>
                            <span class="gain">{w.gain}</span>
                          </div>
                          <p class="watch-specs">{w.specs}</p>
                          <span class="watch-meta">Acquired {w.acquired}</span>
                        </div>
                      ))}
                    </div>
                  )}

                  {it.id === "menswear" &&
                    tailorCountries.map((country) => (
                      <>
                        <div class="sub-head">{country}</div>
                        <ul class="detail-list">
                          {tailors
                            .filter((t) => t.country === country)
                            .sort((a, b) => a.name.localeCompare(b.name))
                            .map((t) => {
                              const fits = t.gallery ? mwMap[t.gallery] || [] : [];
                              return (
                                <li class="tailor-li">
                                  <div class="tailor-row">
                                    <span>
                                      {t.instagram ? (
                                        <a class="inline" href={t.instagram} target="_blank" rel="noopener">
                                          <b>{t.name}</b>
                                        </a>
                                      ) : (
                                        <b>{t.name}</b>
                                      )}
                                    </span>
                                    <span class="meta">{t.specialty}</span>
                                  </div>
                                  {fits.length > 0 && (
                                    <div class="acc-item outfit-acc">
                                      <button class="acc-head">
                                        <span class="acc-name">Outfits</span>
                                        <span class="acc-sign">+</span>
                                      </button>
                                      <div class="acc-panel">
                                        <div class="acc-inner">
                                          <div class="shots outfit-shots">
                                            {fits.map((f) => (
                                              <button
                                                class="shot"
                                                data-full={`/photos/menswear/${t.gallery}/${f}`}
                                                data-cap={t.name}
                                              >
                                                <img src={`/photos/menswear/${t.gallery}/thumb/${f}`} alt={t.name} loading="lazy" />
                                              </button>
                                            ))}
                                          </div>
                                        </div>
                                      </div>
                                    </div>
                                  )}
                                </li>
                              );
                            })}
                        </ul>
                      </>
                    ))}

                  {it.id === "crypto" && (
                    <>
                      <ul class="detail-list">
                        {crypto.map((c) => (
                          <li>
                            <span>{c.text}</span>
                            <span class="meta">{c.year}</span>
                          </li>
                        ))}
                      </ul>
                      <p style="margin-top:14px">
                        X:{" "}
                        <a class="inline" href="https://x.com/dnggen" target="_blank" rel="noopener">
                          @dnggen
                        </a>
                      </p>
                    </>
                  )}

                  {it.id === "food" && (
                    <>
                      <p style="margin-bottom:6px">
                        Beli:{" "}
                        <a class="inline" href="https://beliapp.com" target="_blank" rel="noopener">@dnggen</a>
                      </p>
                      <div class="sub-head">Michelin</div>
                      <ul class="detail-list">
                        {fineDining.map((r) => (
                          <li>
                            <span>
                              <b>{r.name}</b>
                              <span class="r-city">{r.city ? ` · ${r.city}` : ""}</span>
                            </span>
                            <span class="meta rating">{r.rating}/5</span>
                          </li>
                        ))}
                      </ul>
                      <div class="sub-head">Cheap eats</div>
                      <ul class="detail-list">
                        {cheapEats.map((r) => (
                          <li>
                            <span>
                              <b>{r.name}</b>
                              <span class="r-city">{r.city ? ` · ${r.city}` : ""}</span>
                            </span>
                            <span class="meta rating">{r.rating}/5</span>
                          </li>
                        ))}
                      </ul>
                      <div class="sub-head">Food crawls</div>
                      <ul class="detail-list">
                        {crawls.map((c) => (
                          <li>
                            <span>
                              <a class="inline" href={c.url} target="_blank" rel="noopener">{c.title}</a>
                            </span>
                            <span class="meta">{c.date}</span>
                          </li>
                        ))}
                      </ul>
                    </>
                  )}

                  {it.id === "travel" && (
                    <ul class="travel">
                      {travel.map((t) => (
                        <li>
                          <b>{t.country}</b>
                          {t.places ? ` — ${t.places}` : ""}
                          {t.date ? <span class="t-date"> · {t.date}</span> : ""}
                        </li>
                      ))}
                    </ul>
                  )}

                  {it.id === "photography" && (
                    <p style="margin-top:4px">
                      <a class="inline" href="/photography">View the full gallery →</a>
                    </p>
                  )}
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <section id="building">
      <h2 class="sec-title">Building</h2>
      <p class="xxx">{site.building}</p>
    </section>

    <section id="contact" class="contact">
      <h2 class="sec-title">Contact</h2>
      <div class="socials">
        <button class="email-link" id="emailBtn" type="button">Email</button>
        {
          site.socials.map((s) => (
            <a href={s.href} target="_blank" rel="noopener">
              {s.label}
            </a>
          ))
        }
      </div>
    </section>
  </div>
</Base>
