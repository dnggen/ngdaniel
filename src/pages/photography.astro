---
import Base from "../layouts/Base.astro";
import photos from "../data/photos.json";
---

<Base title="Photography — Daniel Ng" description="Photography by Daniel Ng.">
  <div class="wrap">
    <header class="mast">
      <a href="/" class="name" style="text-decoration:none;color:inherit">Daniel Ng</a>
    </header>

    <section style="border-bottom:0">
      <h2 class="sec-title">Photography</h2>
      <p style="max-width:48ch;margin-bottom:14px">
        Shot on a Sony RX100 VII.
      </p>
      <p style="margin-bottom:8px">
        <a class="inline" href="https://www.instagram.com/ng_daniel_photo/" target="_blank" rel="noopener">Instagram ↗</a>
      </p>

      {
        photos.map((album) => (
          <div class="album-block">
            <h3 class="album-title">{album.title}</h3>
            <span class="album-date">{album.date}</span>
            <div class="shots">
              {album.files.map((f) => (
                <button class="shot" data-full={`/photos/albums/${album.slug}/${f}`} data-cap={album.title}>
                  <img src={`/photos/albums/${album.slug}/thumb/${f}`} alt={album.title} loading="lazy" />
                </button>
              ))}
            </div>
          </div>
        ))
      }
    </section>
  </div>
</Base>
